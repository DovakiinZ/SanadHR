# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# Superpowers SDD scratch (briefs, reports, diffs, progress ledger)
.superpowers/

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

.vercel

# .NET build output
[Bb]in/
[Oo]bj/
*.user

# Azure deploy artifacts
/publish/
/publish.zip

# Python bytecode (from .claude skill scripts)
__pycache__/
*.pyc

# .NET build/publish artifacts
backend/**/bin/
backend/**/obj/
backend/publish-out/

# Backend publish output (deploy artifacts)
backend/publish/
